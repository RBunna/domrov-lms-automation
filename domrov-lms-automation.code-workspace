{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"code-runner.runInTerminal": true,
		"files.autoSave": "afterDelay",
		"editor.fontFamily": "Fira Code, Consolas, 'Courier New', monospace",
		"editor.fontVariations": false,
		"editor.autoIndent": "full",
		"editor.formatOnSave": true,
		"editor.formatOnType": true,
		"editor.formatOnPaste": true,
		"editor.inlineSuggest.enabled": true,
		"editor.quickSuggestions": {
			"other": true,
			"comments": false,
			"strings": false
		},
		"editor.detectIndentation": true,
		"editor.linkedEditing": true,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"terminal.integrated.defaultProfile.windows": "CMD (UTF-8)",
		"terminal.integrated.profiles.windows": {
			"CMD (UTF-8)": {
				"path": "cmd.exe",
				"args": [
					"/K",
					"chcp 65001"
				]
			},
			"PowerShell": {
				"source": "PowerShell",
				"icon": "terminal-powershell",
				"args": [
					"-NoLogo",
					"-NoExit",
					"-Command",
					"chcp 65001"
				]
			}
		},
		"terminal.integrated.fontFamily": "Cascadia Code, Consolas, 'Courier New', monospace",
		"files.associations": {
			"*.java": "java"
		},
		"json.schemas": [],
		"workbench.colorTheme": "Default Light+",
		"workbench.iconTheme": "material-icon-theme",
		"workbench.editor.enablePreview": false,
		"workbench.secondarySideBar.defaultVisibility": "hidden",
		"workbench.settings.applyToAllProfiles": [],
		"explorer.confirmDelete": false,
		"explorer.confirmDragAndDrop": false,
		"explorer.confirmPasteNative": false,
		"liveServer.settings.donotShowInfoMsg": true,
		"insert-unicode.show-identified-characters-in-file": true,
		"git.confirmSync": false,
		"git.enableSmartCommit": true,
		"github.copilot.enable": true,
		"github.copilot.inlineSuggest.enable": true,
		"github.copilot.nextEditSuggestions.enabled": true,
		"gitlens.ai.model": "vscode",
		"gitlens.ai.vscode.model": "copilot:gpt-4.1",
		"code-runner.executorMap": {
			"javascript": "node",
			"typescript": "ts-node",
			"java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
			"c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
			"cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt.exe && ./$fileNameWithoutExt.exe",
			"python": "py -u",
			"php": "php",
			"go": "go run",
			"powershell": "powershell -ExecutionPolicy ByPass -File",
			"bash": "bash"
		},
		"update.mode": "manual",
		"security.workspace.trust.untrustedFiles": "open",
		"telemetry.telemetryLevel": "off"
	}
}