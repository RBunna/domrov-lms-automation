# 📋 Example terraform.tfvars for Cloudflare DNS (Refactored)
# 
# CHANGE NOTES: This file has been updated to use Cloudflare DNS instead of AWS Route53
# 
# INSTRUCTIONS:
# 1. Copy the content below
# 2. Update ONLY the values marked with [CHANGE THIS]
# 3. For database password, use: export TF_VAR_db_pass="YourPassword123!"
# 4. For Cloudflare API token, use: export TF_VAR_cloudflare_api_token="your-token"

# ============================================================
# AWS REGION & COMPUTE
# ============================================================
region        = "ap-southeast-1"
ami_id        = "ami-0e7ff22101b84bcff"  # Ubuntu 22.04 LTS in ap-southeast-1
key_name      = "domrov-prod-key"         # [CHANGE THIS] - Your EC2 key pair name
instance_type = "t3.medium"

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
db_user = "domrov_admin"

# DO NOT SET db_pass HERE - Use environment variable instead:
# export TF_VAR_db_pass="YourSecurePassword123!@#"

# ============================================================
# CLOUDFLARE DNS CONFIGURATION (NEW - Replaces Route53)
# ============================================================
# CHANGE NOTES:
# - Replaces AWS Route53 with Cloudflare for DNS management
# - Enables Cloudflare proxy (orange cloud) for SSL/TLS and CDN
# - Requires valid ACM certificates on CloudFront origins

# Get from Cloudflare Dashboard:
# https://dash.cloudflare.com/ → Select your domain → Overview tab
# Zone ID is shown at the bottom right
cloudflare_zone_id = "Z1234567890abcdef"   # [CHANGE THIS] - Your Cloudflare Zone ID

# Enable Cloudflare proxy for DNS records
# true  = Cloudflare acts as CDN/proxy (orange cloud) - requires SSL certificates
# false = DNS only, no proxying (gray cloud)
cloudflare_proxy_enabled = true

# ============================================================
# ADMIN ACCESS & SECURITY
# ============================================================
admin_cidr_blocks = ["203.0.113.0/24"]    # [CHANGE THIS] - Your office/VPN IP range

# ============================================================
# AUTO SCALING GROUP
# ============================================================
asg_min_size         = 2
asg_max_size         = 4
asg_desired_capacity = 2

# ============================================================
# DATABASE (RDS PostgreSQL)
# ============================================================
rds_multi_az                = true
rds_allocated_storage       = 100
rds_backup_retention_period = 30

# ============================================================
# FRONTEND DOMAINS
# ============================================================
# These domains will be created as CNAME records in Cloudflare
# pointing to CloudFront distributions
domain_names = ["domrov.app", "admin.domrov.app"]  # [CHANGE THIS] - Your domain names

# ============================================================
# SSL/TLS CERTIFICATE (Optional)
# ============================================================
# Leave empty to use CloudFront default certificate
# OR set to your ACM certificate ARN for custom domain SSL
acm_certificate_arn = ""

# ============================================================
# ENVIRONMENT VARIABLES (Required - Set Before Running Terraform)
# ============================================================
# 
# 1. DATABASE PASSWORD
#    export TF_VAR_db_pass="YourSecurePassword123!@#"
# 
# 2. CLOUDFLARE API TOKEN (REQUIRED - New)
#    To generate:
#    1. Go to: https://dash.cloudflare.com/profile/api-tokens
#    2. Click: "Create Token"
#    3. Select: "Edit zone DNS" template (or create custom)
#    4. Choose: Your domain in "Zone Resources"
#    5. Click: "Continue to summary"
#    6. Click: "Create Token"
#    
#    Then set:
#    export TF_VAR_cloudflare_api_token="your-api-token-here"
#
# 3. AWS CREDENTIALS (for AWS provider)
#    export AWS_ACCESS_KEY_ID="your-access-key"
#    export AWS_SECRET_ACCESS_KEY="your-secret-key"
#    OR use: export AWS_PROFILE="your-profile"
