# 📋 Example terraform.tfvars - Copy and Paste Ready!
# 
# INSTRUCTIONS:
# 1. Copy the content below
# 2. Update ONLY the values marked with [CHANGE THIS]
# 3. For database password, use: export TF_VAR_db_pass="YourPassword123!"

# ============================================================
# AWS REGION & COMPUTE
# ============================================================
region        = "ap-southeast-1"
ami_id        = "ami-0e7ff22101b84bcff"  # Ubuntu 22.04 LTS in ap-southeast-1
key_name      = "domrov-prod-key"         # [CHANGE THIS] - Your EC2 key pair name
instance_type = "t3.medium"

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
db_user = "domrov_admin"

# DO NOT SET db_pass HERE - Use environment variable instead:
# export TF_VAR_db_pass="YourSecurePassword123!@#"
# Or for production, use AWS Secrets Manager:
# export TF_VAR_db_pass=$(aws secretsmanager get-secret-value --secret-id domrov-db-password --query SecretString --output text)

# ============================================================
# DNS & DOMAIN
# ============================================================
hosted_zone_id    = "Z0123456789ABC"      # [CHANGE THIS] - Your Route53 hosted zone ID
admin_cidr_blocks = ["203.0.113.0/24"]    # [CHANGE THIS] - Your office/VPN IP range
domain_names      = ["domrov.app", "admin.domrov.app"]  # [CHANGE THIS] - Your domain names

# ============================================================
# AUTO SCALING GROUP
# ============================================================
asg_min_size         = 2
asg_max_size         = 4
asg_desired_capacity = 2

# ============================================================
# DATABASE (RDS PostgreSQL)
# ============================================================
rds_multi_az                = true
rds_allocated_storage       = 100
rds_backup_retention_period = 30

# ============================================================
# SSL/TLS CERTIFICATE (Optional)
# ============================================================
acm_certificate_arn = ""  # Leave empty or set to your ACM certificate ARN
